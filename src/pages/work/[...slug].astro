---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id.replace(/\.md$/, '') },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Emilio Melis`} description={entry.data.description}>
	<article class="project-page stack gap-15">
		<header class="project-header wrapper">
			<a class="back-link" href="/Portfolio/#selected-work">← Back to work</a>
			<div class="header-content stack gap-8">
				<div class="title-group stack gap-4">
					<h1 class="title">{entry.data.title}</h1>
					<p class="thesis">{entry.data.description}</p>
				</div>
				
				<div class="meta-strip">
					<div class="tags">
						{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
					</div>
					<div class="actions">
						<a class="action-link primary" href={entry.data.repoUrl} target="_blank" rel="noopener noreferrer">View Repository</a>
						{entry.data.demoUrl && (
							<a class="action-link" href={entry.data.demoUrl} target="_blank" rel="noopener noreferrer">Live Demo</a>
						)}
					</div>
				</div>
			</div>
		</header>

		<main class="wrapper">
			<div class="layout-grid">
				<div class="content-col">
					<div class="prose">
						<Content />
					</div>
				</div>
				
				{entry.data.img && (
					<aside class="media-col">
						<div class="media-container">
							<img src={entry.data.img} alt={entry.data.img_alt || ''} loading="eager" />
						</div>
					</aside>
				)}
			</div>
		</main>
	</article>
</BaseLayout>

<style>
	.project-page {
		padding-top: 2rem;
		padding-bottom: 6rem;
	}

	.project-header {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 3rem;
	}

	.back-link {
		display: inline-block;
		color: var(--gray-400);
		font-size: 0.9rem;
		margin-bottom: 3rem;
		font-family: var(--font-brand);
	}

	.title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		color: var(--gray-0);
		letter-spacing: -0.03em;
		margin: 0;
	}

	.thesis {
		font-size: clamp(1.1rem, 2vw, 1.25rem);
		color: var(--gray-300);
		max-width: 48rem;
		line-height: 1.6;
		margin: 0;
	}

	.meta-strip {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-top: 1rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.action-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.25rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 4px;
		color: var(--gray-200);
		font-size: 0.9rem;
		font-family: var(--font-brand);
		transition: all var(--theme-transition);
	}

	.action-link.primary {
		background: var(--gray-0);
		color: var(--gray-999);
		border-color: var(--gray-0);
		font-weight: 500;
	}

	.action-link:hover {
		background: rgba(255, 255, 255, 0.08);
		color: var(--gray-0);
	}

	.action-link.primary:hover {
		background: var(--gray-200);
		border-color: var(--gray-200);
	}

	.layout-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

	.prose {
		color: var(--gray-200);
		font-size: 1.05rem;
		line-height: 1.75;
		max-width: 48rem;
	}

	.prose :global(h2),
	.prose :global(h3) {
		color: var(--gray-0);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		letter-spacing: -0.01em;
	}

	.prose :global(h2) { font-size: 1.75rem; }
	.prose :global(h3) { font-size: 1.35rem; }

	.prose :global(p) {
		margin-bottom: 1.25rem;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.25rem;
		padding-left: 1.25rem;
	}

	.prose :global(li) {
		margin-bottom: 0.5rem;
	}

	.prose :global(code) {
		background: rgba(255, 255, 255, 0.05);
		padding: 0.2em 0.4em;
		border-radius: 3px;
		font-family: monospace;
		font-size: 0.9em;
		color: var(--accent-light);
	}

	.media-container {
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 4px;
		overflow: hidden;
		background: rgba(0, 0, 0, 0.5);
	}

	.media-container img {
		width: 100%;
		height: auto;
		display: block;
		filter: contrast(1.1) brightness(0.9);
	}

	@media (min-width: 64em) {
		.meta-strip {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}

		.layout-grid {
			grid-template-columns: 1fr 1fr;
			align-items: start;
		}

		.media-col {
			position: sticky;
			top: 6rem;
		}
	}
</style>
