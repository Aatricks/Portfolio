---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import Hero from '../../components/Hero.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}


export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id.replace(/\.md$/, '') },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<Hero title={entry.data.title} align="start" variant="page">
						<div class="details">
							<div class="stack gap-4 details-copy">
								<div class="tags">
									{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
								</div>
								<p class="description">{entry.data.description}</p>
								<div class="actions">
									<a class="action-link primary" href={entry.data.repoUrl}>View repo</a>
									{
										entry.data.demoUrl && (
											<a class="action-link" href={entry.data.demoUrl}>Live demo</a>
										)
									}
								</div>
							</div>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="detail-grid">
					{
						entry.data.img && (
							<div class="detail-media">
								<img src={entry.data.img} alt={entry.data.img_alt || ''} />
							</div>
						)
					}
					<div class="prose">
						<Content />
					</div>
				</div>
			</main>
		</div>
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: flex-start;
		width: 100%;
	}

	.details-copy {
		align-items: flex-start;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.description {
		font-size: 1.02rem;
		max-width: 58ch;
		color: var(--gray-200);
		line-height: 1.72;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.action-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.65rem 1rem;
		border: 1px solid color-mix(in srgb, var(--gray-700) 24%, transparent);
		border-radius: 999rem;
		background: color-mix(in srgb, var(--gray-999) 92%, transparent);
		text-decoration: none;
		color: var(--gray-100);
		font-size: 0.98rem;
		transition:
			border-color var(--theme-transition),
			background-color var(--theme-transition),
			color var(--theme-transition);
	}

	.action-link.primary {
		background: var(--gray-0);
		border-color: transparent;
		color: var(--gray-999);
	}

	.action-link:hover,
	.action-link:focus {
		border-color: color-mix(in srgb, var(--gray-500) 38%, transparent);
		background: color-mix(in srgb, var(--gray-900) 82%, transparent);
	}

	.action-link.primary:hover,
	.action-link.primary:focus {
		background: color-mix(in srgb, var(--gray-0) 88%, var(--accent-dark) 12%);
	}

	.detail-grid {
		display: grid;
		gap: 1.75rem;
		align-items: start;
	}

	.detail-media img {
		width: 100%;
		max-height: min(72vh, 42rem);
		object-fit: contain;
		object-position: top center;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.prose {
		max-width: 66ch;
		font-size: 1.02rem;
		line-height: 1.72;
	}

	.prose > :global(* + *) {
		margin-top: 1rem;
	}

	.prose :global(h1),
	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4),
	.prose :global(h5) {
		margin: 1.5rem 0;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-inline-start: 1.2rem;
	}

	.prose :global(li + li) {
		margin-top: 0.45rem;
	}

	.prose :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.1;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		color: var(--gray-0);
	}

	.prose :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.prose :global(a:hover),
	.prose :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.details {
			gap: 2rem;
		}

		.detail-grid {
			grid-template-columns: minmax(0, 1.16fr) minmax(20rem, 0.84fr);
			gap: clamp(2rem, 4vw, 3.25rem);
		}

		.detail-media {
			position: sticky;
			top: 1.2rem;
		}

		.prose :global(blockquote) {
			font-size: var(--text-2xl);
		}
	}
</style>
