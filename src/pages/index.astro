---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';

const featuredProjects = (await getCollection('work'))
	.filter((project) => project.data.featured)
	.sort((a, b) => (a.data.featuredOrder ?? 999) - (b.data.featuredOrder ?? 999))
	.slice(0, 3);
---

<BaseLayout
	title="Emilio Melis | Aatricks"
	description="Android-native AI tooling focused on local inference, runtime constraints, and product-grade implementation."
>
	<div class="stack page-shell">
		<section class="hero wrapper">
			<div class="hero-copy stack gap-4">
				<h1>Android-native AI tools built for real device constraints.</h1>
				<p class="lede">
					I build local inference software where runtime ownership, memory budgets, packaging,
					and interface quality matter as much as model output.
				</p>
			</div>
		</section>

		<section class="wrapper">
			<ul class="featured-grid">
				{
					featuredProjects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</ul>
		</section>

		<section class="wrapper about-band" id="about">
			<p class="eyebrow">About</p>
			<div class="about-grid">
				<p class="about-copy">
					I focus on the layer where models become products: Android APIs, native runtimes,
					fallback paths, packaging, and the performance work that keeps local AI usable.
				</p>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.page-shell {
		gap: clamp(2.4rem, 6vw, 4.75rem);
		padding-bottom: 4.5rem;
	}

	.hero {
		padding-top: clamp(2rem, 5vw, 3.75rem);
		padding-bottom: 0.25rem;
	}

	.eyebrow {
		color: var(--gray-300);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.8rem;
	}

	.hero-copy {
		max-width: 58rem;
	}

	.hero h1 {
		font-size: clamp(2.9rem, 6vw, 5rem);
		line-height: 0.96;
		letter-spacing: -0.055em;
		max-width: 11.5ch;
	}

	.lede,
	.about-copy,
	.about-note {
		color: var(--gray-200);
	}

	.lede {
		max-width: 39rem;
		font-size: clamp(1.02rem, 1.35vw, 1.16rem);
		line-height: 1.72;
	}

	.section-head {
		display: grid;
		gap: 0.45rem;
		max-width: 56rem;
	}

	.section-note {
		max-width: 38rem;
		color: var(--gray-300);
		font-size: 0.98rem;
		line-height: 1.65;
	}

	.featured-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1.15rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		padding-top: 0.2rem;
	}

	.hero-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.8rem;
		padding: 0.7rem 1rem;
		border-radius: 999rem;
		border: 1px solid color-mix(in srgb, var(--gray-700) 28%, transparent);
		color: var(--gray-100);
		text-decoration: none;
		font-size: 0.95rem;
		transition:
			border-color var(--theme-transition),
			background-color var(--theme-transition),
			color var(--theme-transition);
	}

	.hero-link:hover,
	.hero-link:focus {
		border-color: color-mix(in srgb, var(--gray-500) 38%, transparent);
		background: color-mix(in srgb, var(--gray-900) 78%, transparent);
	}

	.hero-link-primary {
		background: var(--gray-0);
		border-color: transparent;
		color: var(--gray-999);
	}

	.hero-link-primary:hover,
	.hero-link-primary:focus {
		background: color-mix(in srgb, var(--gray-0) 88%, var(--accent-dark) 12%);
	}

	.about-band {
		display: grid;
		gap: 0.75rem;
		padding-top: 1.1rem;
	}

	.about-grid {
		display: grid;
		gap: 0.9rem;
		max-width: 58rem;
	}

	.about-copy {
		max-width: 38rem;
		font-size: 0.98rem;
		line-height: 1.7;
	}

	.about-note {
		color: var(--gray-300);
		font-size: 0.95rem;
		line-height: 1.65;
	}

	@media (min-width: 50em) {
		.section-head {
			grid-template-columns: minmax(12rem, 0.45fr) minmax(0, 1fr);
			align-items: end;
			column-gap: 1.5rem;
		}

		.featured-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1.4rem;
		}

		.about-grid {
			grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.8fr);
			align-items: start;
		}
	}
</style>
