---
import MainHead from '../components/MainHead.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<div class="backgrounds"></div>
		<div class="stack content-wrapper">
			<slot />
			<Footer />
		</div>
		<script>
			import Lenis from '@studio-freight/lenis';
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
			const revealNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
			const parallaxNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
			const debounce = <T extends (...args: never[]) => void>(callback: T, delay = 150) => {
				let timeoutId: number | undefined;
				return (...args: Parameters<T>) => {
					window.clearTimeout(timeoutId);
					timeoutId = window.setTimeout(() => callback(...args), delay);
				};
			};
			const parallaxState = parallaxNodes.map((node) => ({
				node,
				speed: Number(node.getAttribute('data-parallax')) || 0.08,
				centerY: 0,
			}));

			revealNodes.forEach((node) => {
				if (prefersReducedMotion.matches) {
					node.classList.add('is-visible');
				}
			});

			if (!prefersReducedMotion.matches && revealNodes.length > 0) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
							}
						});
					},
					{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
				);

				revealNodes.forEach((node) => observer.observe(node));
			}

			let viewportHeight = window.innerHeight || 1;

			const emitScrollState = (
				scroll: number,
				limit: number,
				velocity: number,
				progress = limit > 0 ? scroll / limit : 0,
			) => {
				window.dispatchEvent(
					new CustomEvent('site:scroll', {
						detail: { scroll, limit, velocity, progress },
					}),
				);
			};

			const refreshParallax = (scrollPosition = window.scrollY || 0) => {
				viewportHeight = window.innerHeight || 1;

				parallaxState.forEach((entry) => {
					const rect = entry.node.getBoundingClientRect();
					entry.centerY = scrollPosition + rect.top + rect.height / 2;
				});
			};

			const applyParallax = (scrollPosition: number) => {
				if (prefersReducedMotion.matches) {
					parallaxNodes.forEach((node) => node.style.setProperty('--parallax-shift', '0px'));
					return;
				}

				const viewportCenter = scrollPosition + viewportHeight / 2;
				parallaxState.forEach((entry) => {
					const centerOffset = entry.centerY - viewportCenter;
					entry.node.style.setProperty('--parallax-shift', `${(-centerOffset * entry.speed).toFixed(2)}px`);
				});
			};

			let lenis: Lenis | null = null;
			if (!prefersReducedMotion.matches) {
				lenis = new Lenis({
					duration: 1.15,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					orientation: 'vertical',
					gestureOrientation: 'vertical',
					smoothWheel: true,
					wheelMultiplier: 1,
					touchMultiplier: 1.5,
					infinite: false,
				});

				lenis.on('scroll', ({ scroll, limit, velocity, progress }) => {
					applyParallax(scroll);
					emitScrollState(scroll, limit, velocity, progress);
				});

				const raf = (time: number) => {
					lenis?.raf(time);
					requestAnimationFrame(raf);
				};

				requestAnimationFrame(raf);
			}

			const getScrollPosition = () => lenis?.scroll ?? window.scrollY ?? 0;
			refreshParallax(getScrollPosition());
			applyParallax(getScrollPosition());
			emitScrollState(getScrollPosition(), lenis?.limit ?? 0, 0);

			const handleResize = debounce(() => {
				refreshParallax(getScrollPosition());
				applyParallax(getScrollPosition());
				emitScrollState(getScrollPosition(), lenis?.limit ?? 0, 0);
			});

			window.addEventListener('resize', handleResize);

			window.addEventListener('load', () => {
				refreshParallax(getScrollPosition());
				applyParallax(getScrollPosition());
				emitScrollState(getScrollPosition(), lenis?.limit ?? 0, 0);
			});
		</script>

		<style>
			.backgrounds {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				z-index: -1;
				background-color: var(--gray-999);
				background-image: url('/Portfolio/assets/backgrounds/site-shell-dark.webp');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}

			.content-wrapper {
				min-height: 100vh;
			}
			@media (forced-colors: active) {
				.backgrounds {
					background: none;
				}
			}
		</style>
	</body>
</html>
