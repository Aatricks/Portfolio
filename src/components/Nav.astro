---
const utilityLinks = [
	{ label: 'Work', href: '/Portfolio/#selected-work' },
	{ label: 'Focus', href: '/Portfolio/#about' },
	{ label: 'Resume', href: '/Portfolio/resume.pdf' }
];
---

<nav class="site-nav wrapper" aria-label="Site">
	<a class="site-title" href="/Portfolio/">
		<span class="site-name">Emilio Melis</span>
	</a>
	<div class="utility-links">
		{
			utilityLinks.map(({ href, label }) => (
				<a href={href} class="utility-link">
					{label}
				</a>
			))
		}
	</div>
</nav>

<style>
	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.5rem;
		padding-bottom: 1.5rem;
		font-family: var(--font-brand);
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(6, 8, 13, 0.85);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.03);
	}

	.site-title {
		display: inline-flex;
		align-items: center;
		color: var(--gray-0);
		text-decoration: none;
		font-weight: 500;
		letter-spacing: -0.01em;
	}

	.site-name {
		font-size: 1rem;
	}

	.utility-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 1.5rem;
	}

	.utility-link {
		color: var(--gray-300);
		text-decoration: none;
		font-size: 0.9rem;
		transition: color var(--theme-transition);
	}

	.utility-link:hover,
	.utility-link:focus {
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.site-nav {
			padding-top: 2rem;
			padding-bottom: 2rem;
		}
	}
</style>
