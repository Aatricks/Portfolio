---
const utilityLinks = [
	{ label: 'GitHub', href: 'https://github.com/Aatricks' },
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/in/emilio-melis-14a801338/' },
	{ label: 'Contact', href: 'mailto:melis.emilio1@gmail.com' },
];
---

<nav class="site-nav wrapper" aria-label="Site">
	<a class="site-title" href="/Portfolio/">
		<span class="site-mark">Aatricks</span>
		<span class="site-name">Emilio Melis</span>
	</a>
	<div class="utility-links">
		{
			utilityLinks.map(({ href, label }) => (
				<a href={href} class="utility-link">
					{label}
				</a>
			))
		}
	</div>
</nav>

<style>
	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1rem;
		padding-bottom: 0.35rem;
		font-family: var(--font-brand);
	}

	.site-title {
		display: inline-flex;
		flex-direction: column;
		gap: 0.12rem;
		color: inherit;
		text-decoration: none;
	}

	.site-mark {
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-size: 0.75rem;
		color: var(--gray-0);
	}

	.site-name {
		font-size: 0.9rem;
		letter-spacing: -0.02em;
		color: var(--gray-300);
	}

	.utility-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.85rem;
	}

	.utility-link {
		display: inline-flex;
		align-items: center;
		color: var(--gray-300);
		text-decoration: none;
		font-size: 0.92rem;
		text-underline-offset: 0.22em;
		text-decoration: 1px solid underline transparent;
		transition:
			color var(--theme-transition),
			text-decoration-color var(--theme-transition);
	}

	.utility-link:hover,
	.utility-link:focus {
		color: var(--gray-100);
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.site-nav {
			padding-top: 1.15rem;
			padding-bottom: 0.55rem;
		}
	}
</style>
