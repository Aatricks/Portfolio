---
import type { CollectionEntry } from 'astro:content';
import ProjectActions from './ProjectActions.astro';
import ProjectMetrics from './ProjectMetrics.astro';
import ProjectGallery from './ProjectGallery.astro';

const { entry, Content } = Astro.props as {
	entry: CollectionEntry<'work'>;
	Content: any;
};
---

<article class="project-page project-page--cchess" data-project-theme="cchess">
	<header class="project-page__hero wrapper">
		<a class="project-page__back" href="/Portfolio/#additional-work">Back to work</a>
		<div class="project-page__hero-grid">
			<div class="project-page__hero-copy">
				<p class="project-page__eyebrow">{entry.data.eyebrow}</p>
				<h1>{entry.data.title}</h1>
				<p class="project-page__thesis">{entry.data.thesis}</p>
				<p class="project-page__description">{entry.data.description}</p>
				<ul class="project-page__hero-points">
					{entry.data.heroPoints.map((point) => (
						<li>{point}</li>
					))}
				</ul>
				<p class="project-page__stack">{entry.data.stackLine}</p>
				<ProjectActions
					repoUrl={entry.data.repoUrl}
					docsUrl={entry.data.docsUrl}
					demoUrl={entry.data.demoUrl}
				/>
			</div>

			<div class="project-page__board">
				<div class="project-page__board-grid" aria-hidden="true">
					{Array.from({ length: 64 }).map((_, index) => (
						<span class={index % 2 === (Math.floor(index / 8) % 2) ? 'light' : 'dark'}></span>
					))}
				</div>
				<div class="project-page__board-copy">
					<p class="project-page__section-label">Search layers</p>
					{entry.data.architecture.map((step, index) => (
						<p><strong>{index + 1}.</strong> {step}</p>
					))}
				</div>
			</div>
		</div>
	</header>

	<main class="wrapper project-page__body">
		<ProjectMetrics metrics={entry.data.metrics} />

		<section class="project-page__split">
			<ProjectGallery items={entry.data.gallery} columns="single" />
			<div class="project-page__highlights" data-reveal>
				<p class="project-page__section-label">Why I keep it in the portfolio</p>
				<div class="project-page__highlight-list">
					{entry.data.highlights.map((highlight) => (
						<p>{highlight}</p>
					))}
				</div>
			</div>
		</section>

		<section class="project-page__notes" data-reveal>
			<p class="project-page__section-label">Engineering notes</p>
			<div class="project-prose">
				<Content />
			</div>
		</section>
	</main>
</article>

<style>
	.project-page--cchess {
		--project-accent: #62d3d7;
		padding-top: 1.5rem;
		padding-bottom: 5rem;
	}

	.project-page__hero {
		padding-top: 1.5rem;
		padding-bottom: 3rem;
	}

	.project-page__back,
	.project-page__eyebrow,
	.project-page__stack,
	.project-page__section-label {
		font-family: var(--font-mono);
	}

	.project-page__back {
		display: inline-flex;
		margin-bottom: 1.5rem;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--gray-500);
	}

	.project-page__hero-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.3rem;
	}

	.project-page__eyebrow,
	.project-page__section-label {
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--project-accent) 42%, var(--gray-300));
	}

	.project-page h1 {
		margin-top: 0.8rem;
		font-size: clamp(2.7rem, 6vw, 5rem);
		line-height: 0.96;
		max-width: 10ch;
	}

	.project-page__thesis {
		margin-top: 1.1rem;
		max-width: 38rem;
		font-size: clamp(1.06rem, 2vw, 1.28rem);
		line-height: 1.75;
		color: var(--gray-50);
	}

	.project-page__description {
		margin-top: 0.95rem;
		max-width: 37rem;
		line-height: 1.8;
		color: var(--gray-300);
	}

	.project-page__hero-points {
		display: grid;
		gap: 0.75rem;
		margin-top: 1.2rem;
		padding: 0;
		list-style: none;
	}

	.project-page__hero-points li,
	.project-page__board-copy p,
	.project-page__highlight-list p {
		line-height: 1.8;
		color: var(--gray-200);
	}

	.project-page__stack {
		margin: 1.4rem 0 1.6rem;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--gray-500);
	}

	.project-page__board,
	.project-page__highlights,
	.project-page__notes {
		padding: 1.3rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.6rem;
		background: rgba(255, 255, 255, 0.03);
	}

	.project-page__board-grid {
		display: grid;
		grid-template-columns: repeat(8, 1fr);
		overflow: hidden;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.06);
	}

	.project-page__board-grid span {
		aspect-ratio: 1 / 1;
	}

	.project-page__board-grid .light {
		background: rgba(255, 255, 255, 0.12);
	}

	.project-page__board-grid .dark {
		background: rgba(98, 211, 215, 0.18);
	}

	.project-page__board-copy {
		display: grid;
		gap: 0.7rem;
		margin-top: 1rem;
	}

	.project-page__body {
		display: grid;
		gap: 2rem;
	}

	.project-page__split {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		align-items: start;
	}

	.project-page__highlight-list {
		display: grid;
		gap: 0.85rem;
		margin-top: 1rem;
	}

	.project-page__highlight-list p {
		padding-top: 0.85rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.project-prose {
		display: grid;
		gap: 1rem;
		margin-top: 1rem;
		max-width: 52rem;
		font-size: 1rem;
		line-height: 1.85;
		color: var(--gray-200);
	}

	.project-prose :global(h2),
	.project-prose :global(h3) {
		margin-top: 1.5rem;
		font-size: 1.35rem;
	}

	.project-prose :global(p),
	.project-prose :global(ul) {
		margin: 0;
	}

	.project-prose :global(ul) {
		padding-left: 1.2rem;
	}

	.project-prose :global(code) {
		padding: 0.1rem 0.35rem;
		border-radius: 0.35rem;
		background: rgba(255, 255, 255, 0.06);
		color: white;
	}

	@media (min-width: 68em) {
		.project-page__hero-grid {
			grid-template-columns: minmax(0, 0.95fr) minmax(20rem, 0.82fr);
			align-items: start;
			gap: 2rem;
		}

		.project-page__split {
			grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1fr);
		}
	}
</style>
