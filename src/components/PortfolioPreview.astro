---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
	image?: string;
}

const { project, image } = Astro.props;
const { data, slug } = project;
---

<a class="project-card" href={`/Portfolio/work/${slug}`}>
	<div class="media">
		<img src={image || data.img} alt={data.img_alt || ''} loading="eager" decoding="async" />
	</div>
	<div class="copy">
		<h3 class="title">{data.title}</h3>
		<p class="description">{data.description}</p>
	</div>
</a>

<style>
	.project-card {
		display: grid;
		grid-template-rows: minmax(15rem, 17rem) auto;
		background: color-mix(in srgb, var(--gray-999) 96%, var(--accent-dark) 4%);
		border: 1px solid color-mix(in srgb, var(--gray-700) 24%, transparent);
		border-radius: 1rem;
		overflow: clip;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		transition:
			border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.project-card:hover,
	.project-card:focus {
		border-color: color-mix(in srgb, var(--gray-500) 40%, transparent);
		box-shadow: var(--shadow-sm);
	}

	.media {
		position: relative;
		overflow: hidden;
		background: color-mix(in srgb, var(--gray-900) 72%, var(--accent-dark) 28%);
	}

	.media::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 20%, rgba(7, 9, 15, 0.18));
		pointer-events: none;
	}

	.project-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.copy {
		padding: 0.95rem 0.95rem 1.05rem;
	}

	.title {
		font-size: clamp(1.3rem, 1.8vw, 1.65rem);
		line-height: 1;
		letter-spacing: -0.035em;
		color: var(--gray-0);
		margin-bottom: 0.42rem;
	}

	.description {
		color: var(--gray-200);
		font-size: 0.93rem;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
