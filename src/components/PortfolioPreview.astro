---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
	variant?: 'dominant' | 'secondary';
}

const { project, variant = 'secondary' } = Astro.props;
const { data, id } = project;
const href = `/Portfolio/work/${id.replace(/\.md$/, '')}`;
---

<a class={`project-card ${variant}`} href={href}>
	<div class="content-wrapper">
		<div class="copy">
			<div class="header">
				<h3 class="title">{data.title}</h3>
				<span class="arrow">→</span>
			</div>
			<p class="description">{data.description}</p>
			
			<div class="tags">
				{data.tags.map((tag) => (
					<span class="tag">{tag}</span>
				))}
			</div>
		</div>
		
		<div class="media">
			<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
		</div>
	</div>
</a>

<style>
	.project-card {
		display: block;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.01);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 4px;
		overflow: hidden;
		transition: border-color var(--theme-transition), background var(--theme-transition);
	}

	.project-card:hover {
		border-color: rgba(255, 255, 255, 0.15);
		background: rgba(255, 255, 255, 0.03);
	}

	.content-wrapper {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.dominant .content-wrapper {
		display: grid;
		grid-template-columns: 1fr;
	}

	.copy {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		flex: 1;
	}

	.header {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.title {
		font-size: 1.5rem;
		color: var(--gray-0);
		margin: 0;
	}

	.arrow {
		color: var(--accent-regular);
		font-family: monospace;
		font-size: 1.2rem;
		opacity: 0;
		transform: translateX(-10px);
		transition: all var(--theme-transition);
	}

	.project-card:hover .arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.description {
		color: var(--gray-300);
		font-size: 1rem;
		line-height: 1.6;
		margin: 0;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: auto;
	}

	.tag {
		font-size: 0.75rem;
		padding: 0.25rem 0.75rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 20px;
		color: var(--gray-400);
		font-family: var(--font-brand);
	}

	.media {
		position: relative;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		background: #000;
	}

	.media::after {
		content: '';
		position: absolute;
		inset: 0;
		background: inset 0 0 20px rgba(0,0,0,0.5);
		pointer-events: none;
	}

	img {
		width: 100%;
		height: 240px;
		object-fit: cover;
		object-position: top;
		filter: contrast(1.1) brightness(0.9);
		transition: filter var(--theme-transition);
	}

	.project-card:hover img {
		filter: contrast(1.1) brightness(1);
	}

	.dominant img {
		height: 320px;
	}

	@media (min-width: 50em) {
		.dominant .content-wrapper {
			grid-template-columns: 1fr 1.2fr;
			align-items: stretch;
		}

		.dominant .media {
			border-top: none;
			border-left: 1px solid rgba(255, 255, 255, 0.05);
			height: 100%;
		}

		.dominant img {
			height: 100%;
			min-height: 400px;
		}

		.dominant .copy {
			padding: 3rem;
		}

		.dominant .title {
			font-size: 2rem;
		}

		.dominant .description {
			font-size: 1.15rem;
		}
	}
</style>
