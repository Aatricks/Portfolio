---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
	variant?: 'dominant' | 'secondary';
}

const { project, variant = 'secondary' } = Astro.props;
const { data, id } = project;
const href = `/Portfolio/work/${id.replace(/\.md$/, '')}`;
const leadMetric = data.metrics[0];
---

<a class={`project-preview ${variant} project-preview--${data.themeKey}`} href={href} data-reveal>
	<div class="project-preview__copy">
		<div class="project-preview__meta">
			<p class="project-preview__eyebrow">{data.eyebrow}</p>
			{leadMetric && <p class="project-preview__metric">{leadMetric.label}: {leadMetric.value}</p>}
		</div>
		<div class="project-preview__header">
			<h3 class="project-preview__title">{data.title}</h3>
			<span class="project-preview__arrow" aria-hidden="true">→</span>
		</div>
		<p class="project-preview__thesis">{data.thesis}</p>
		<p class="project-preview__stack">{data.stackLine}</p>
	</div>
	<div class="project-preview__media">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
	</div>
</a>

<style>
	.project-preview {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		text-decoration: none;
		padding: 1.5rem 0;
		border-top: 1px solid rgba(255, 255, 255, 0.07);
		color: inherit;
	}

	.project-preview.secondary {
		min-height: 100%;
	}

	.project-preview__copy {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.project-preview__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem 1rem;
		align-items: center;
	}

	.project-preview__eyebrow {
		font-size: 0.74rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--gray-500);
	}

	.project-preview__metric {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--gray-400);
	}

	.project-preview__header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
	}

	.project-preview__title {
		font-size: clamp(1.7rem, 3vw, 2.75rem);
	}

	.project-preview__arrow {
		font-size: 1.1rem;
		color: var(--gray-400);
		transform: translateX(-0.35rem);
		transition:
			transform var(--theme-transition),
			color var(--theme-transition),
			opacity var(--theme-transition);
		opacity: 0.5;
	}

	.project-preview:hover .project-preview__arrow {
		transform: translateX(0);
		color: var(--gray-0);
		opacity: 1;
	}

	.project-preview__thesis {
		max-width: 34rem;
		font-size: 1.04rem;
		line-height: 1.65;
		color: var(--gray-200);
	}

	.project-preview__stack {
		max-width: 34rem;
		font-size: 0.86rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--gray-500);
	}

	.project-preview__media {
		position: relative;
		border: 1px solid rgba(255, 255, 255, 0.07);
		border-radius: 1.5rem;
		overflow: hidden;
		background:
			radial-gradient(circle at top, rgba(114, 139, 255, 0.16), transparent 40%),
			rgba(8, 11, 19, 0.9);
	}

	.project-preview__media::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0.06), rgba(0, 0, 0, 0.3));
		pointer-events: none;
	}

	.project-preview__media img {
		width: 100%;
		height: 100%;
		min-height: 16rem;
		object-fit: cover;
		filter: contrast(1.05) brightness(0.82);
		transition: transform 0.7s ease, filter 0.7s ease;
	}

	.project-preview:hover .project-preview__media img {
		transform: scale(1.03);
		filter: contrast(1.07) brightness(0.95);
	}

	.project-preview--llmedge .project-preview__media {
		background:
			radial-gradient(circle at top, rgba(121, 167, 255, 0.2), transparent 42%),
			rgba(8, 11, 19, 0.92);
	}

	.project-preview--lightdiffusion-next .project-preview__media {
		background:
			radial-gradient(circle at top, rgba(244, 180, 88, 0.18), transparent 42%),
			rgba(8, 11, 19, 0.92);
	}

	.project-preview--easyreader .project-preview__media {
		background:
			radial-gradient(circle at top, rgba(131, 209, 255, 0.16), transparent 42%),
			rgba(8, 11, 19, 0.92);
		display: grid;
		place-items: center;
		padding: 1rem;
	}

	.project-preview--easyreader .project-preview__media img {
		width: auto;
		max-width: 100%;
		max-height: 16rem;
		min-height: 0;
		object-fit: contain;
		border-radius: 1rem;
	}

	.project-preview--cchess .project-preview__media {
		background:
			radial-gradient(circle at top, rgba(98, 211, 215, 0.16), transparent 42%),
			rgba(8, 11, 19, 0.92);
	}

	.secondary .project-preview__title {
		font-size: clamp(1.45rem, 2vw, 1.9rem);
	}

	.secondary .project-preview__thesis,
	.secondary .project-preview__stack {
		max-width: 100%;
	}

	.secondary .project-preview__media img {
		min-height: 12rem;
	}

	@media (min-width: 64em) {
		.project-preview.dominant {
			grid-template-columns: minmax(0, 0.95fr) minmax(26rem, 0.9fr);
			gap: 3rem;
			align-items: center;
			padding: 2.5rem 0 1.5rem;
		}

		.project-preview.secondary {
			align-content: start;
		}
	}
</style>
