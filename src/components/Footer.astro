---
const currentYear = new Date().getFullYear();
---

<footer id="contact">
	<div class="group">
		<p>
			Open to internships and engineering conversations in on-device AI, Android, and
			runtime-heavy software.
		</p>
		<a
			href="mailto:melis.emilio1@gmail.com"
			target="_blank"
			rel="noreferrer"
			class="contact-link"
		>
			melis.emilio1@gmail.com
		</a>
	</div>
	<p class="meta">© {currentYear}</p>
</footer>

<style>
	footer {
		display: flex;
		position: relative;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: auto;
		padding: 3rem 1.5rem 2.6rem;
		color: var(--gray-300);
		font-size: 0.97rem;
		border-top: 1px solid color-mix(in srgb, var(--gray-700) 16%, transparent);
	}

	.group {
		display: grid;
		gap: 0.4rem;
		max-width: 32rem;
		line-height: 1.65;
	}

	.contact-link {
		color: var(--gray-100);
		text-decoration: none;
	}

	footer a {
		color: var(--gray-400);
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.22em;
		transition: text-decoration-color var(--theme-transition);
	}

	footer a:hover,
	footer a:focus {
		text-decoration-color: currentColor;
	}

	.meta {
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		footer {
			flex-direction: row;
			justify-content: space-between;
			align-items: flex-end;
			padding: 2.5rem 5rem 2.2rem;
		}
	}
</style>
