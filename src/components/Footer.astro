---
const currentYear = new Date().getFullYear();
---

<footer id="contact" class="wrapper">
	<div class="footer-content">
		<div class="group">
			<p class="tagline">Edge AI, native runtimes, and local-first software.</p>
			<div class="contact-links">
				<a href="mailto:melis.emilio1@gmail.com" class="contact-link">Email</a>
				<span class="separator">/</span>
				<a href="https://github.com/Aatricks" class="contact-link" target="_blank" rel="noopener noreferrer">GitHub</a>
				<span class="separator">/</span>
				<a href="https://www.linkedin.com/in/emilio-melis-14a801338/" class="contact-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				<span class="separator">/</span>
				<a href="/Portfolio/CV-English.pdf" class="contact-link">Resume</a>
			</div>
		</div>
		<p class="meta">© {currentYear} Emilio Melis</p>
	</div>
</footer>

<style>
	footer {
		margin-top: 6rem;
		padding-top: 3rem;
		padding-bottom: 3rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.tagline {
		color: var(--gray-0);
		font-size: 1rem;
		font-weight: 500;
		max-width: 28rem;
	}

	.contact-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.contact-link {
		color: var(--gray-300);
		text-decoration: none;
		font-size: 0.95rem;
		transition: color var(--theme-transition);
	}

	.contact-link:hover {
		color: var(--gray-0);
	}

	.separator {
		color: var(--gray-700);
		font-size: 0.9rem;
	}

	.meta {
		color: var(--gray-500);
		font-size: 0.85rem;
	}

	@media (min-width: 50em) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
			align-items: flex-end;
		}
		
		.group {
			gap: 0.75rem;
		}
	}
</style>
