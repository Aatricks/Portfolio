---
interface Props {
	title: string;
	title2?: string;
	tagline?: string;
	align?: 'start' | 'center';
	variant?: 'display' | 'page';
}

const { align = 'center', tagline, title, title2, variant = 'display' } = Astro.props;
---

<div class:list={['hero stack gap-4', align, variant]}>
	<div class="stack gap-2">
		<h1 class="title">{title}</h1>
		{title2 && <h1 class="title muted">{title2}</h1>}
		{tagline && <p class="tagline">{tagline}</p>}
	</div>
	<slot />
</div>

<style>
	.hero {
		font-size: var(--text-lg);
		text-align: center;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.title {
		font-size: clamp(2.4rem, 6vw, 4.75rem);
		color: var(--gray-0);
		text-align: center;
		letter-spacing: -0.055em;
		line-height: 0.95;
		max-width: 12ch;
		text-wrap: balance;
	}

	.title.muted {
		color: var(--gray-300);
	}

	.tagline {
		max-width: 38rem;
		margin-inline: auto;
		color: var(--gray-300);
	}

	.page .title {
		font-size: clamp(2.45rem, 4.35vw, 3.85rem);
		max-width: 16ch;
	}

	@media (min-width: 50em) {
		.hero {
			font-size: var(--text-xl);
		}

		.start {
			text-align: start;
			align-items: flex-start;
		}

		.start .title,
		.start .tagline {
			margin-inline: unset;
			text-align: start;
		}
	}
</style>
