{
  "name": "pink-photon",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "node ./node_modules/astro/bin/astro.mjs dev",
    "start": "node ./node_modules/astro/bin/astro.mjs dev",
    "build": "node ./node_modules/astro/bin/astro.mjs build",
    "check": "node ./node_modules/astro/bin/astro.mjs check",
    "preview": "node ./node_modules/astro/bin/astro.mjs preview",
    "preview:local": "node ./node_modules/astro/bin/astro.mjs preview --host 127.0.0.1 --port 4321",
    "smoke:site": "node scripts/site-smoke.mjs",
    "smoke:site:fresh": "npm run build && npm run smoke:site",
    "astro": "node ./node_modules/astro/bin/astro.mjs"
  },
  "dependencies": {
    "@studio-freight/lenis": "^1.0.34",
    "astro": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3"
  }
}
